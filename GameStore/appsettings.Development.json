{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileLogging": {
    "LogDirectory": "Logs",
    "LogFilePrefix": "gamestore",
    "ExceptionFilePrefix": "gamestore-exceptions",
    "MinimumLevel": "Information"
  },
  "PaymentMicroservice": {
    "IBoxUrl": "http://localhost:5000/api/payments/ibox",
    "VisaUrl": "http://localhost:5000/api/payments/visa",
    "RetryCount": 3
  },
  "BankPayment": {
    "InvoiceValidityDays": 30
  }
}
